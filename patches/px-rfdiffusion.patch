+#!/usr/bin/env python3
+"""ProteinSketch2AI two-step RFdiffusion entrypoint."""
+
+from __future__ import annotations
+
+import argparse
+import logging
+import sys
+from dataclasses import dataclass
+from pathlib import Path
+
+REPO_ROOT = Path(__file__).resolve().parents[2]
+if str(REPO_ROOT) not in sys.path:
+    sys.path.insert(0, str(REPO_ROOT))
+
+from rfdiffusion.openvdb_compat import preload_openvdb
+
+preload_openvdb()
+
+import torch
+from omegaconf import OmegaConf
+
+from rfdiffusion import volume_sketch
+from rfdiffusion.inference import utils as iu
+from pdb_utils import (
+    chamfer_distance,
+    detect_monomer_length,
+    detect_target_contig,
+    pdb_chain_xyz,
+    validate_intermediate_geometry,
+    write_intermediate,
+)
+from rfdiffusion_runner import (
+    cleanup_monomer_outputs,
+    configure_binder_stage,
+    configure_monomer_stage,
+    make_deterministic,
+    normalize_contig,
+    run_stage,
+)
+
+
+@dataclass(frozen=True)
+class PipelinePaths:
+    config: Path
+    sketch_input: Path
+    target_pdb: Path
+    outpath: Path
+    monomer_output_prefix: Path
+    binder_output_prefix: Path
+    intermediate_dir: Path
+
+
+def resolve_path(path_str: str) -> Path:
+    return Path(path_str).expanduser().resolve()
+
+
+def resolve_with_outpath(path_str: str, outpath: Path) -> Path:
+    path = Path(path_str).expanduser()
+    if not path.is_absolute():
+        path = outpath / path
+    return path.resolve()
+
+
+def default_outpath(source_path: Path) -> Path:
+    return (Path.cwd() / "outputs" / f"two_step_{source_path.stem}").resolve()
+
+
+def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
+    default_config = REPO_ROOT / "config" / "inference" / "voxel.yaml"
+    parser = argparse.ArgumentParser(
+        description="Run monomer -> intermediate -> binder inference from ProteinSketch2AI .ps2ai.",
+        formatter_class=argparse.RawDescriptionHelpFormatter,
+        epilog=(
+            "Minimal example:\n"
+            "  python scripts/two-step/run_inference_json_twostep.py \\\n"
+            "    inference.sketch_input=proteinsketch.ps2ai \\\n"
+            "    inference.output_prefix=outputs/two_step_ps2ai/binder \\\n"
+            "    inference.num_designs=10"
+        ),
+    )
+
+    paths = parser.add_argument_group("paths")
+    paths.add_argument("--config", default=str(default_config), help="Inference YAML config")
+    paths.add_argument("--outpath", default=None, help="Default: outputs/two_step_<ps2ai_stem>")
+    paths.add_argument("--monomer-output-prefix", default=None, help="Default: <outpath>/monomer")
+    paths.add_argument("--binder-output-prefix", default=None, help="Default: <outpath>/binder")
+    paths.add_argument("--intermediate-dir", default=None, help="Default: <outpath>/intermediate")
+
+    stage = parser.add_argument_group("stage controls")
+    stage.add_argument("--monomer-contig", default=None, help="Default: volume estimatedMinResidueLength-estimatedMaxResidueLength")
+    stage.add_argument("--monomer-num-designs", type=int, default=None)
+    stage.add_argument("--monomer-design-startnum", type=int, default=None)
+    stage.add_argument("--partial-T", type=int, default=None)
+    stage.add_argument("--target-chain-out", default="B")
+    stage.add_argument("--deterministic", action=argparse.BooleanOptionalAction, default=None)
+    stage.add_argument("--write-trajectory", action=argparse.BooleanOptionalAction, default=None)
+    stage.add_argument("--skip-monomer-inference", action="store_true")
+    stage.add_argument("--skip-binder-inference", action="store_true")
+    stage.add_argument("--keep-monomer", action="store_true")
+
+    potentials = parser.add_argument_group("potential weights")
+    potentials.add_argument("--monomer-shell-weight", type=float, default=0.1)
+    potentials.add_argument("--monomer-distance-weight", type=float, default=0.001)
+    potentials.add_argument("--binder-shell-weight", type=float, default=0.1)
+    potentials.add_argument("--binder-distance-weight", type=float, default=0.001)
+    potentials.add_argument("--interface-weight", type=float, default=1.0)
+    potentials.add_argument("--guide-decay", default=None)
+
+    sketch = parser.add_argument_group("ProteinSketch VDB options")
+    sketch.add_argument("--volume-sketch-cutoff", type=float, default=None)
+    sketch.add_argument("--volume-sketch-max-sdf", type=float, default=None)
+    sketch.add_argument("--sketch-json-volume-index", type=int, default=None)
+
+    filtering = parser.add_argument_group("monomer filter")
+    filtering.add_argument("--chamfer-cutoff", type=float, default=9.0)
+    filtering.add_argument("--skip-chamfer-filter", action="store_true")
+
+    diagnostics = parser.add_argument_group("diagnostics")
+    diagnostics.add_argument("--no-validate-intermediate", action="store_true")
+    diagnostics.add_argument("--log-level", choices=["DEBUG", "INFO", "WARNING", "ERROR"], default="INFO")
+    args, overrides = parser.parse_known_args(argv)
+    for override in overrides:
+        if override.startswith("--") or "=" not in override:
+            parser.error(f"unrecognized argument: {override}")
+    args.config_overrides = overrides
+    return args
+
+
+def setup_logging(level: str) -> None:
+    logging.basicConfig(
+        level=getattr(logging, level),
+        format="[%(asctime)s] %(levelname)s: %(message)s",
+        datefmt="%H:%M:%S",
+    )
+
+
+def override_keys(args: argparse.Namespace) -> set[str]:
+    return {item.split("=", 1)[0] for item in getattr(args, "config_overrides", [])}
+
+
+def load_config(args: argparse.Namespace):
+    conf = OmegaConf.load(str(resolve_path(args.config)))
+    if args.config_overrides:
+        conf = OmegaConf.merge(conf, OmegaConf.from_dotlist(args.config_overrides))
+    return conf
+
+
+def cfg_get(conf_node, key: str, default=None):
+    if conf_node is None:
+        return default
+    if hasattr(conf_node, "get"):
+        return conf_node.get(key, default)
+    return getattr(conf_node, key, default)
+
+
+def cli_or_override(
+    args: argparse.Namespace,
+    attr: str,
+    conf_node,
+    conf_key: str,
+    dotted_key: str,
+    default,
+    keys: set[str],
+):
+    value = getattr(args, attr)
+    if value is not None:
+        return value
+    if dotted_key in keys:
+        return cfg_get(conf_node, conf_key, default)
+    return default
+
+
+def apply_effective_options(args: argparse.Namespace, conf, keys: set[str]) -> None:
+    inf_conf = conf.inference
+    args.sketch_input = cfg_get(inf_conf, "sketch_input", None)
+    args.monomer_num_designs = int(
+        cli_or_override(args, "monomer_num_designs", inf_conf, "num_designs", "inference.num_designs", 2, keys)
+    )
+    args.monomer_design_startnum = int(
+        cli_or_override(
+            args,
+            "monomer_design_startnum",
+            inf_conf,
+            "design_startnum",
+            "inference.design_startnum",
+            0,
+            keys,
+        )
+    )
+    args.partial_T = int(
+        cli_or_override(args, "partial_T", conf.diffuser, "partial_T", "diffuser.partial_T", 10, keys)
+    )
+    args.write_trajectory = bool(
+        cli_or_override(
+            args,
+            "write_trajectory",
+            inf_conf,
+            "write_trajectory",
+            "inference.write_trajectory",
+            False,
+            keys,
+        )
+    )
+    args.deterministic = bool(
+        cli_or_override(
+            args,
+            "deterministic",
+            inf_conf,
+            "deterministic",
+            "inference.deterministic",
+            False,
+            keys,
+        )
+    )
+    args.guide_decay = str(
+        cli_or_override(args, "guide_decay", conf.potentials, "guide_decay", "potentials.guide_decay", "linear", keys)
+    )
+    if args.volume_sketch_cutoff is None:
+        args.volume_sketch_cutoff = cfg_get(inf_conf, "volume_sketch_cutoff", None)
+    if args.volume_sketch_cutoff is None:
+        args.volume_sketch_cutoff = -1.0
+    args.volume_sketch_cutoff = float(args.volume_sketch_cutoff)
+
+    if args.volume_sketch_max_sdf is None:
+        args.volume_sketch_max_sdf = cfg_get(inf_conf, "volume_sketch_max_sdf", 0.0)
+    args.volume_sketch_max_sdf = float(args.volume_sketch_max_sdf)
+
+    if args.sketch_input_volume_index is None:
+        args.sketch_input_volume_index = cfg_get(inf_conf, "sketch_input_volume_index", 0)
+    args.sketch_input_volume_index = int(args.sketch_input_volume_index or 0)
+
+
+def validate_args(args: argparse.Namespace) -> None:
+    if not args.sketch_input:
+        raise ValueError("Two-step ProteinSketch inference requires inference.sketch_input")
+    if not volume_sketch.proteinsketch_has_section(args.sketch_input, "target"):
+        raise ValueError("Two-step ProteinSketch2AI requires targets[0] PDB data")
+    if not volume_sketch.proteinsketch_has_section(args.sketch_input, "volume"):
+        raise ValueError("Two-step ProteinSketch2AI requires volumes[0] OpenVDB data")
+    if args.monomer_num_designs < 1:
+        raise ValueError("--monomer-num-designs must be >= 1")
+    if args.monomer_design_startnum < 0:
+        raise ValueError("--monomer-design-startnum must be >= 0")
+    if args.partial_T < 1:
+        raise ValueError("--partial-T must be >= 1")
+    if args.chamfer_cutoff <= 0:
+        raise ValueError("--chamfer-cutoff must be > 0")
+    if len(args.target_chain_out) != 1:
+        raise ValueError("--target-chain-out must be exactly one character")
+
+
+def resolve_pipeline_paths(args: argparse.Namespace, conf, keys: set[str]) -> PipelinePaths:
+    sketch_input = resolve_path(args.sketch_input)
+    output_prefix = cfg_get(conf.inference, "output_prefix", None)
+    config_binder_prefix = output_prefix if "inference.output_prefix" in keys else None
+    if args.outpath:
+        outpath = resolve_path(args.outpath)
+    elif config_binder_prefix:
+        outpath = resolve_path(str(config_binder_prefix)).parent
+    else:
+        outpath = default_outpath(sketch_input)
+
+    target_pdb = volume_sketch.write_proteinsketch_pdb(
+        sketch_input,
+        "target",
+        outpath / "json_target.pdb",
+        chain_id=None,
+        renumber=False,
+    )
+    return PipelinePaths(
+        config=resolve_path(args.config),
+        sketch_input=sketch_input,
+        target_pdb=target_pdb,
+        outpath=outpath,
+        monomer_output_prefix=(
+            outpath / "monomer"
+            if args.monomer_output_prefix is None
+            else resolve_with_outpath(args.monomer_output_prefix, outpath)
+        ),
+        binder_output_prefix=(
+            resolve_path(str(config_binder_prefix))
+            if args.binder_output_prefix is None and config_binder_prefix
+            else outpath / "binder"
+            if args.binder_output_prefix is None
+            else resolve_with_outpath(args.binder_output_prefix, outpath)
+        ),
+        intermediate_dir=(
+            outpath / "intermediate"
+            if args.intermediate_dir is None
+            else resolve_with_outpath(args.intermediate_dir, outpath)
+        ),
+    )
+
+
+def validate_paths(paths: PipelinePaths) -> None:
+    for label, path in {
+        "config": paths.config,
+        "ProteinSketch2AI": paths.sketch_input,
+        "target PDB": paths.target_pdb,
+    }.items():
+        if not path.exists():
+            raise FileNotFoundError(f"Missing {label}: {path}")
+
+
+def shell_points(
+    args: argparse.Namespace,
+    paths: PipelinePaths,
+    *,
+    centered: bool,
+) -> torch.Tensor:
+    points, _geometries = volume_sketch.volume_sketch_points(
+        paths.sketch_input,
+        cutoff=args.volume_sketch_cutoff,
+        max_sdf=args.volume_sketch_max_sdf,
+        volume_index=args.sketch_input_volume_index,
+        centered=centered,
+    )
+    if points.numel() == 0:
+        raise ValueError(f"No ProteinSketch VDB shell points found in {paths.sketch_input}")
+    return points
+
+
+def compute_shell_com(args: argparse.Namespace, paths: PipelinePaths) -> tuple[float, float, float]:
+    points = shell_points(args, paths, centered=False)
+    com = points.mean(dim=0)
+    return (float(com[0]), float(com[1]), float(com[2]))
+
+
+def prepare_shell_points(args: argparse.Namespace, paths: PipelinePaths) -> torch.Tensor | None:
+    if args.skip_chamfer_filter:
+        logging.info("Chamfer filter disabled.")
+        return None
+    shell_xyz = shell_points(args, paths, centered=True)
+    logging.info(
+        "Chamfer filter: sketch_input=%s n=%d cutoff=%.3f",
+        paths.sketch_input,
+        shell_xyz.shape[0],
+        args.chamfer_cutoff,
+    )
+    return shell_xyz
+
+
+def load_sampler(args: argparse.Namespace, paths: PipelinePaths, conf):
+    conf.inference.deterministic = bool(args.deterministic)
+    conf.inference.write_trajectory = bool(args.write_trajectory)
+    conf.inference.output_prefix = str(paths.monomer_output_prefix)
+    conf.inference.num_designs = int(args.monomer_num_designs)
+    conf.inference.design_startnum = int(args.monomer_design_startnum)
+    conf.inference.sketch_input = None
+    conf.inference.input_pdb = None
+    conf.inference.volume_sketch_cutoff = args.volume_sketch_cutoff
+    conf.inference.volume_sketch_max_sdf = args.volume_sketch_max_sdf
+    conf.inference.sketch_input_volume_index = int(args.sketch_input_volume_index)
+    conf.potentials.guide_decay = args.guide_decay
+
+    if args.deterministic:
+        make_deterministic()
+
+    if torch.cuda.is_available():
+        logging.info("GPU: %s", torch.cuda.get_device_name(torch.cuda.current_device()))
+    else:
+        logging.warning("No GPU detected; running on CPU.")
+
+    sampler = iu.sampler_selector(conf)
+    logging.info("RFdiffusion sampler loaded once.")
+    return sampler
+
+
+def design_volume_sketch_points_path(paths: PipelinePaths, conf, design_idx: int) -> Path:
+    output_path = cfg_get(conf.inference, "volume_sketch_points_path", None)
+    if output_path:
+        output_text = str(output_path)
+        if "{design_idx}" in output_text:
+            return resolve_with_outpath(output_text.format(design_idx=design_idx), paths.outpath)
+        path = resolve_with_outpath(output_text, paths.outpath)
+        return path.with_name(f"{path.stem}_{design_idx}{path.suffix}")
+    return Path(f"{paths.binder_output_prefix}_{design_idx}_volume_sketch_points.pdb")
+
+
+def write_binder_volume_sketch_points_if_requested(sampler, paths: PipelinePaths, conf, design_idx: int) -> Path | None:
+    if not cfg_get(conf.inference, "write_volume_sketch_points", False):
+        return None
+
+    inf_conf = sampler.inf_conf
+    previous_path = cfg_get(inf_conf, "volume_sketch_points_path", None)
+    previous_write = cfg_get(inf_conf, "write_volume_sketch_points", False)
+    inf_conf.write_volume_sketch_points = True
+    inf_conf.volume_sketch_points_path = str(
+        design_volume_sketch_points_path(paths, conf, design_idx)
+    )
+    try:
+        written = iu.write_volume_sketch_points_if_requested(sampler)
+    finally:
+        inf_conf.volume_sketch_points_path = previous_path
+        inf_conf.write_volume_sketch_points = previous_write
+    logging.info("Wrote volume sketch points: %s", written)
+    return written
+
+
+def main() -> None:
+    args = parse_args()
+    setup_logging(args.log_level)
+    conf = load_config(args)
+    keys = override_keys(args)
+    apply_effective_options(args, conf, keys)
+    validate_args(args)
+
+    paths = resolve_pipeline_paths(args, conf, keys)
+    validate_paths(paths)
+    paths.outpath.mkdir(parents=True, exist_ok=True)
+    paths.intermediate_dir.mkdir(parents=True, exist_ok=True)
+    paths.monomer_output_prefix.parent.mkdir(parents=True, exist_ok=True)
+    paths.binder_output_prefix.parent.mkdir(parents=True, exist_ok=True)
+
+    if args.monomer_contig:
+        monomer_contig = args.monomer_contig
+    else:
+        length_range = volume_sketch.proteinsketch_volume_length_range(
+            paths.sketch_input,
+            volume_index=args.sketch_input_volume_index,
+        )
+        if length_range is None:
+            raise ValueError(
+                "ProteinSketch2AI volume requires estimatedMinResidueLength and "
+                "estimatedMaxResidueLength or --monomer-contig"
+            )
+        monomer_contig = f"[{length_range}]"
+    logging.info("Output directory: %s", paths.outpath)
+    logging.info("Monomer contig: %s", normalize_contig(monomer_contig))
+
+    monomer_coord_shift = compute_shell_com(args, paths)
+    logging.info("Monomer back-translation delta: %.3f %.3f %.3f", *monomer_coord_shift)
+
+    sampler = load_sampler(args, paths, conf)
+    configure_monomer_stage(
+        sampler,
+        target_pdb=paths.target_pdb,
+        sketch_input=paths.sketch_input,
+        monomer_contig=monomer_contig,
+        monomer_output_prefix=paths.monomer_output_prefix,
+        num_designs=args.monomer_num_designs,
+        design_startnum=args.monomer_design_startnum,
+        write_trajectory=args.write_trajectory,
+        guide_decay=args.guide_decay,
+        monomer_shell_weight=args.monomer_shell_weight,
+        monomer_distance_weight=args.monomer_distance_weight,
+        volume_sketch_cutoff=args.volume_sketch_cutoff,
+        volume_sketch_max_sdf=args.volume_sketch_max_sdf,
+        sketch_input_volume_index=args.sketch_input_volume_index,
+    )
+
+    if args.skip_monomer_inference:
+        logging.info("Skipping monomer stage.")
+    else:
+        logging.info("Running monomer stage.")
+        run_stage(
+            sampler,
+            deterministic=args.deterministic,
+            start_idx=args.monomer_design_startnum,
+            num_designs=args.monomer_num_designs,
+        )
+
+    target_contig = detect_target_contig(paths.target_pdb, args.target_chain_out)
+    shell_xyz = prepare_shell_points(args, paths)
+    kept = 0
+    skipped = 0
+
+    start = args.monomer_design_startnum
+    stop = start + args.monomer_num_designs
+    for design_idx in range(start, stop):
+        monomer_pdb = Path(f"{paths.monomer_output_prefix}_{design_idx}.pdb")
+        if not monomer_pdb.exists():
+            raise FileNotFoundError(f"Expected monomer PDB not found: {monomer_pdb}")
+
+        if shell_xyz is not None:
+            monomer_xyz = pdb_chain_xyz(monomer_pdb, {"CA"}, chain_id="A")
+            if monomer_xyz.numel() == 0:
+                raise ValueError(f"No chain-A CA atoms parsed from {monomer_pdb}")
+            cd = chamfer_distance(monomer_xyz, shell_xyz)
+            if cd >= args.chamfer_cutoff:
+                logging.info("Skipping %d: chamfer %.3f >= %.3f", design_idx, cd, args.chamfer_cutoff)
+                skipped += 1
+                if not args.keep_monomer:
+                    cleanup_monomer_outputs(
+                        paths.monomer_output_prefix,
+                        design_idx,
+                        remove_trajectory=args.write_trajectory,
+                    )
+                continue
+            kept += 1
+            logging.info("Keeping %d: chamfer %.3f < %.3f", design_idx, cd, args.chamfer_cutoff)
+
+        intermediate_pdb = paths.intermediate_dir / f"intermediate_{design_idx}.pdb"
+        write_intermediate(
+            monomer_pdb=monomer_pdb,
+            target_pdb=paths.target_pdb,
+            out_pdb=intermediate_pdb,
+            target_chain_out=args.target_chain_out,
+            monomer_coord_shift=monomer_coord_shift,
+        )
+        if not args.no_validate_intermediate:
+            validate_intermediate_geometry(
+                monomer_pdb,
+                paths.target_pdb,
+                intermediate_pdb,
+                monomer_coord_shift,
+            )
+
+        monomer_len = detect_monomer_length(monomer_pdb, preferred_chain="A")
+        binder_contig = f"[{monomer_len}-{monomer_len}/0 {target_contig}]"
+        configure_binder_stage(
+            sampler,
+            target_pdb=paths.target_pdb,
+            intermediate_pdb=intermediate_pdb,
+            sketch_input=paths.sketch_input,
+            binder_contig=binder_contig,
+            binder_output_prefix=paths.binder_output_prefix,
+            design_startnum=design_idx,
+            partial_t=args.partial_T,
+            write_trajectory=args.write_trajectory,
+            guide_decay=args.guide_decay,
+            binder_shell_weight=args.binder_shell_weight,
+            binder_distance_weight=args.binder_distance_weight,
+            interface_weight=args.interface_weight,
+            volume_sketch_cutoff=args.volume_sketch_cutoff,
+            volume_sketch_max_sdf=args.volume_sketch_max_sdf,
+            sketch_input_volume_index=args.sketch_input_volume_index,
+        )
+
+        if args.skip_binder_inference:
+            logging.info("Skipping binder stage for %d.", design_idx)
+        else:
+            run_stage(
+                sampler,
+                deterministic=args.deterministic,
+                start_idx=design_idx,
+                num_designs=1,
+                after_sample_init=lambda current_sampler, idx, _prefix: write_binder_volume_sketch_points_if_requested(
+                    current_sampler,
+                    paths,
+                    conf,
+                    idx,
+                ),
+            )
+            if not args.keep_monomer:
+                cleanup_monomer_outputs(
+                    paths.monomer_output_prefix,
+                    design_idx,
+                    remove_trajectory=args.write_trajectory,
+                )
+
+    if shell_xyz is not None:
+        logging.info("Chamfer summary: kept=%d skipped=%d", kept, skipped)
+    logging.info("Two-step inference completed.")
+
+
+if __name__ == "__main__":
+    main()
