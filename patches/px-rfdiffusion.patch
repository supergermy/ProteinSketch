+from __future__ import annotations
+
+
+_OPENVDB_MODULE = None
+_OPENVDB_IMPORT_ERROR: ImportError | None = None
+
+
+def preload_openvdb():
+    """Load OpenVDB before torch can bind an incompatible system libstdc++."""
+    global _OPENVDB_MODULE, _OPENVDB_IMPORT_ERROR
+    if _OPENVDB_MODULE is not None:
+        return _OPENVDB_MODULE
+
+    try:
+        import pyopenvdb as vdb
+    except ImportError as exc:
+        _OPENVDB_IMPORT_ERROR = exc
+        return None
+
+    _OPENVDB_MODULE = vdb
+    _OPENVDB_IMPORT_ERROR = None
+    return _OPENVDB_MODULE
+    return None
+
+
+def import_openvdb():
+    module = preload_openvdb()
+    if module is not None:
+        return module
+
+    hint = (
+        "ProteinSketch VDB volume input requires pyopenvdb. "
+        "Install it in the RFdiffusion conda environment. If pyopenvdb reports "
+        "CXXABI or libtbb errors, run with the conda env lib directory first in "
+        "LD_LIBRARY_PATH."
+    )
+    if _OPENVDB_IMPORT_ERROR is not None:
+        raise ImportError(hint) from _OPENVDB_IMPORT_ERROR
+    raise ImportError(hint)
