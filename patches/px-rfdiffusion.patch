+from __future__ import annotations
+
+import logging
+import os
+import pickle
+import random
+import time
+from pathlib import Path
+from typing import Callable, List
+
+import numpy as np
+import torch
+from omegaconf import OmegaConf
+
+from rfdiffusion.util import writepdb, writepdb_multi
+
+
+def normalize_contig(contig: str) -> str:
+    value = contig.strip()
+    if value.startswith("[") and value.endswith("]"):
+        return value[1:-1].strip()
+    return value
+
+
+def make_deterministic(seed: int = 0) -> None:
+    torch.manual_seed(seed)
+    np.random.seed(seed)
+    random.seed(seed)
+
+
+def cleanup_monomer_outputs(
+    monomer_output_prefix: Path,
+    design_idx: int,
+    *,
+    remove_trajectory: bool,
+) -> None:
+    base = Path(f"{monomer_output_prefix}_{design_idx}")
+    to_remove = [Path(f"{base}.pdb"), Path(f"{base}.trb")]
+    if remove_trajectory:
+        traj_prefix = base.parent / "traj" / base.name
+        to_remove.extend(
+            [
+                Path(f"{traj_prefix}_Xt-1_traj.pdb"),
+                Path(f"{traj_prefix}_pX0_traj.pdb"),
+            ]
+        )
+
+    for path in to_remove:
+        if path.exists():
+            path.unlink()
+
+
+def run_single_design(
+    sampler,
+    out_prefix: str,
+    after_sample_init: Callable[[object, str], None] | None = None,
+) -> None:
+    start_time = time.time()
+
+    x_init, seq_init = sampler.sample_init()
+    if after_sample_init is not None:
+        after_sample_init(sampler, out_prefix)
+    denoised_xyz_stack = []
+    px0_xyz_stack = []
+    seq_stack = []
+    plddt_stack = []
+
+    x_t = torch.clone(x_init)
+    seq_t = torch.clone(seq_init)
+
+    for t in range(int(sampler.t_step_input), sampler.inf_conf.final_step - 1, -1):
+        px0, x_t, seq_t, plddt = sampler.sample_step(
+            t=t, x_t=x_t, seq_init=seq_t, final_step=sampler.inf_conf.final_step
+        )
+        px0_xyz_stack.append(px0)
+        denoised_xyz_stack.append(x_t)
+        seq_stack.append(seq_t)
+        plddt_stack.append(plddt[0])
+
+    denoised_xyz_stack = torch.flip(torch.stack(denoised_xyz_stack), [0])
+    px0_xyz_stack = torch.flip(torch.stack(px0_xyz_stack), [0])
+    plddt_stack = torch.stack(plddt_stack)
+
+    out_path = Path(out_prefix)
+    out_path.parent.mkdir(parents=True, exist_ok=True)
+
+    final_seq = torch.where(
+        torch.argmax(seq_init, dim=-1) == 21, 7, torch.argmax(seq_init, dim=-1)
+    )
+    bfacts = torch.ones_like(final_seq.squeeze())
+    bfacts[torch.where(torch.argmax(seq_init, dim=-1) == 21, True, False)] = 0
+
+    writepdb(
+        f"{out_prefix}.pdb",
+        denoised_xyz_stack[0, :, :4],
+        final_seq,
+        sampler.binderlen,
+        chain_idx=sampler.chain_idx,
+        bfacts=bfacts,
+        idx_pdb=sampler.idx_pdb,
+    )
+
+    trb = dict(
+        config=OmegaConf.to_container(sampler._conf, resolve=True),
+        plddt=plddt_stack.cpu().numpy(),
+        device=torch.cuda.get_device_name(torch.cuda.current_device())
+        if torch.cuda.is_available()
+        else "CPU",
+        time=time.time() - start_time,
+    )
+    if hasattr(sampler, "contig_map"):
+        trb.update(sampler.contig_map.get_mappings())
+    with open(f"{out_prefix}.trb", "wb") as f_out:
+        pickle.dump(trb, f_out)
+
+    if sampler.inf_conf.write_trajectory:
+        traj_prefix = out_path.parent / "traj" / out_path.name
+        traj_prefix.parent.mkdir(parents=True, exist_ok=True)
+        writepdb_multi(
+            f"{traj_prefix}_Xt-1_traj.pdb",
+            denoised_xyz_stack,
+            bfacts,
+            final_seq.squeeze(),
+            use_hydrogens=False,
+            backbone_only=False,
+            chain_ids=sampler.chain_idx,
+        )
+        writepdb_multi(
+            f"{traj_prefix}_pX0_traj.pdb",
+            px0_xyz_stack,
+            bfacts,
+            final_seq.squeeze(),
+            use_hydrogens=False,
+            backbone_only=False,
+            chain_ids=sampler.chain_idx,
+        )
+
+
+def run_stage(
+    sampler,
+    deterministic: bool,
+    start_idx: int,
+    num_designs: int,
+    after_sample_init: Callable[[object, int, str], None] | None = None,
+) -> List[Path]:
+    outputs: List[Path] = []
+    for design_idx in range(start_idx, start_idx + num_designs):
+        if deterministic:
+            make_deterministic(design_idx)
+        out_prefix = f"{sampler.inf_conf.output_prefix}_{design_idx}"
+        output_pdb = Path(out_prefix + ".pdb")
+        if sampler.inf_conf.cautious and output_pdb.exists():
+            logging.getLogger(__name__).info("Skipping existing output: %s", output_pdb)
+            outputs.append(output_pdb)
+            continue
+        hook = None
+        if after_sample_init is not None:
+            hook = lambda current_sampler, current_prefix, idx=design_idx: after_sample_init(
+                current_sampler,
+                idx,
+                current_prefix,
+            )
+        run_single_design(sampler, out_prefix, after_sample_init=hook)
+        outputs.append(output_pdb)
+    return outputs
+
+
+def _configure_guide_source(
+    sampler,
+    *,
+    sketch_input: Path | None,
+    volume_sketch_cutoff: float | None,
+    volume_sketch_max_sdf: float | None,
+    sketch_input_volume_index: int,
+) -> None:
+    if sketch_input is None:
+        raise ValueError("Two-step ProteinSketch inference requires sketch_input")
+
+    sampler.inf_conf.sketch_input = None if sketch_input is None else str(sketch_input)
+    sampler.inf_conf.volume_sketch_cutoff = volume_sketch_cutoff
+    sampler.inf_conf.volume_sketch_max_sdf = volume_sketch_max_sdf
+    sampler.inf_conf.sketch_input_volume_index = int(sketch_input_volume_index)
+
+
+def configure_monomer_stage(
+    sampler,
+    *,
+    target_pdb: Path,
+    sketch_input: Path | None = None,
+    monomer_contig: str,
+    monomer_output_prefix: Path,
+    num_designs: int,
+    design_startnum: int,
+    write_trajectory: bool,
+    guide_decay: str,
+    monomer_shell_weight: float,
+    monomer_distance_weight: float,
+    volume_sketch_cutoff: float | None = None,
+    volume_sketch_max_sdf: float | None = None,
+    sketch_input_volume_index: int = 0,
+) -> None:
+    sampler.inf_conf.input_pdb = str(target_pdb)
+    sampler.inf_conf.output_prefix = str(monomer_output_prefix)
+    sampler.inf_conf.num_designs = int(num_designs)
+    sampler.inf_conf.design_startnum = int(design_startnum)
+    sampler.inf_conf.write_trajectory = bool(write_trajectory)
+    _configure_guide_source(
+        sampler,
+        sketch_input=sketch_input,
+        volume_sketch_cutoff=volume_sketch_cutoff,
+        volume_sketch_max_sdf=volume_sketch_max_sdf,
+        sketch_input_volume_index=sketch_input_volume_index,
+    )
+
+    sampler.diffuser_conf.partial_T = None
+    sampler.contig_conf.contigs = [normalize_contig(monomer_contig)]
+    sampler.potential_conf.guiding_potentials = [
+        f"type:volume_sketch_monomer_shell_ncontacts,weight:{monomer_shell_weight}",
+        f"type:volume_sketch_shell_nearest_monomer_distance,weight:{monomer_distance_weight}",
+    ]
+    sampler.potential_conf.guide_decay = guide_decay
+
+
+def configure_binder_stage(
+    sampler,
+    *,
+    target_pdb: Path,
+    intermediate_pdb: Path,
+    sketch_input: Path | None = None,
+    binder_contig: str,
+    binder_output_prefix: Path,
+    design_startnum: int,
+    partial_t: int,
+    write_trajectory: bool,
+    guide_decay: str,
+    binder_shell_weight: float,
+    binder_distance_weight: float,
+    interface_weight: float,
+    volume_sketch_cutoff: float | None = None,
+    volume_sketch_max_sdf: float | None = None,
+    sketch_input_volume_index: int = 0,
+) -> None:
+    sampler.inf_conf.input_pdb = str(intermediate_pdb)
+    sampler.inf_conf.output_prefix = str(binder_output_prefix)
+    sampler.inf_conf.num_designs = 1
+    sampler.inf_conf.design_startnum = int(design_startnum)
+    sampler.inf_conf.write_trajectory = bool(write_trajectory)
+    _configure_guide_source(
+        sampler,
+        sketch_input=sketch_input,
+        volume_sketch_cutoff=volume_sketch_cutoff,
+        volume_sketch_max_sdf=volume_sketch_max_sdf,
+        sketch_input_volume_index=sketch_input_volume_index,
+    )
+
+    sampler.diffuser_conf.partial_T = int(partial_t)
+    sampler.contig_conf.contigs = [normalize_contig(binder_contig)]
+    sampler.potential_conf.guiding_potentials = [
+        f"type:volume_sketch_binder_shell_ncontacts,weight:{binder_shell_weight},target_pdb_path:{intermediate_pdb}",
+        f"type:volume_sketch_shell_nearest_binder_distance,weight:{binder_distance_weight},target_pdb_path:{intermediate_pdb}",
+        f"type:interface_ncontacts,weight:{interface_weight}",
+    ]
+    sampler.potential_conf.guide_decay = guide_decay
