+++ b/scripts/two-step/pdb_utils.py
@@ -0,0 +1,240 @@
+from __future__ import annotations
+
+import math
+from pathlib import Path
+from typing import Dict, Iterable, List, Sequence, Tuple
+
+import torch
+
+AtomCoord = Tuple[float, float, float]
+
+
+def iter_atom_lines(path: Path) -> Iterable[str]:
+    with path.open("r", encoding="utf-8") as handle:
+        for line in handle:
+            if line.startswith(("ATOM", "HETATM")):
+                yield line.rstrip("\n")
+
+
+def atom_name(line: str) -> str:
+    return line[12:16]
+
+
+def pdb_chain(line: str) -> str:
+    return line[21]
+
+
+def pdb_resseq(line: str) -> int:
+    return int(line[22:26])
+
+
+def pdb_icode(line: str) -> str:
+    return line[26]
+
+
+def pdb_xyz(line: str) -> AtomCoord:
+    return (float(line[30:38]), float(line[38:46]), float(line[46:54]))
+
+
+def pdb_chain_xyz(
+    pdb_path: Path, allowed_atom_names: set[str], chain_id: str | None = None
+) -> torch.Tensor:
+    coords: list[list[float]] = []
+    for line in iter_atom_lines(pdb_path):
+        if chain_id is not None and pdb_chain(line) != chain_id:
+            continue
+        if atom_name(line).strip() not in allowed_atom_names:
+            continue
+        coords.append(list(pdb_xyz(line)))
+    if not coords:
+        return torch.empty((0, 3), dtype=torch.float32)
+    return torch.tensor(coords, dtype=torch.float32)
+
+
+def chamfer_distance(p: torch.Tensor, q: torch.Tensor) -> float:
+    dist = torch.cdist(p, q)
+    return float(dist.min(dim=1).values.mean() + dist.min(dim=0).values.mean())
+
+
+def ordered_target_residue_keys(target_pdb: Path) -> list[tuple[str, int, str]]:
+    residue_keys: list[tuple[str, int, str]] = []
+    seen: set[tuple[str, int, str]] = set()
+    for line in iter_atom_lines(target_pdb):
+        key = (pdb_chain(line), pdb_resseq(line), pdb_icode(line))
+        if key in seen:
+            continue
+        seen.add(key)
+        residue_keys.append(key)
+    return residue_keys
+
+
+def detect_target_contig(target_pdb: Path, target_chain_out: str) -> str:
+    residue_keys = ordered_target_residue_keys(target_pdb)
+    if not residue_keys:
+        raise ValueError(f"No ATOM/HETATM residues found in target PDB: {target_pdb}")
+    return f"{target_chain_out}1-{len(residue_keys)}"
+
+
+def detect_monomer_length(monomer_pdb: Path, preferred_chain: str = "A") -> int:
+    residues_by_chain: Dict[str, set[tuple[int, str]]] = {}
+    for line in iter_atom_lines(monomer_pdb):
+        if atom_name(line) != " CA ":
+            continue
+        chain = pdb_chain(line)
+        residues_by_chain.setdefault(chain, set()).add((pdb_resseq(line), pdb_icode(line)))
+
+    if not residues_by_chain:
+        raise ValueError(f"No CA atoms found in monomer PDB: {monomer_pdb}")
+    if preferred_chain in residues_by_chain and residues_by_chain[preferred_chain]:
+        return len(residues_by_chain[preferred_chain])
+    if len(residues_by_chain) == 1:
+        return len(next(iter(residues_by_chain.values())))
+
+    chains = ", ".join(repr(c) for c in sorted(residues_by_chain))
+    raise ValueError(
+        f"Unable to infer monomer length from chain '{preferred_chain}' in {monomer_pdb}. "
+        f"Available chains: {chains}"
+    )
+
+
+def shift_coord(coord: AtomCoord, coord_shift: AtomCoord | None) -> AtomCoord:
+    if coord_shift is None:
+        return coord
+    dx, dy, dz = coord_shift
+    x, y, z = coord
+    return (x + dx, y + dy, z + dz)
+
+
+def pdb_round_coord(coord: AtomCoord) -> AtomCoord:
+    x, y, z = coord
+    return (float(f"{x:8.3f}"), float(f"{y:8.3f}"), float(f"{z:8.3f}"))
+
+
+def rewrite_atom_line(
+    line: str,
+    serial: int,
+    *,
+    chain_override: str | None = None,
+    coord_shift: AtomCoord | None = None,
+    resseq_override: int | None = None,
+    icode_override: str | None = None,
+) -> str:
+    base = line.rstrip("\n")
+    if len(base) < 80:
+        base = base.ljust(80)
+
+    if coord_shift is not None:
+        x, y, z = shift_coord(pdb_xyz(base), coord_shift)
+        base = f"{base[:30]}{x:8.3f}{y:8.3f}{z:8.3f}{base[54:80]}"
+
+    chain = chain_override if chain_override is not None else base[21]
+    updated = f"{base[:6]}{serial:5d}{base[11:21]}{chain}{base[22:80]}"
+
+    if resseq_override is None and icode_override is None:
+        return updated + "\n"
+    if resseq_override is not None and not (1 <= resseq_override <= 9999):
+        raise ValueError(f"Residue index exceeds PDB field width: {resseq_override}")
+
+    icode = updated[26] if icode_override is None else icode_override
+    if len(icode) != 1:
+        raise ValueError(f"Insertion code override must be one character: {icode!r}")
+    resseq = updated[22:26] if resseq_override is None else f"{resseq_override:4d}"
+    return f"{updated[:22]}{resseq}{icode}{updated[27:]}\n"
+
+
+def write_intermediate(
+    monomer_pdb: Path,
+    target_pdb: Path,
+    out_pdb: Path,
+    target_chain_out: str,
+    monomer_coord_shift: AtomCoord | None = None,
+) -> None:
+    monomer_atoms = list(iter_atom_lines(monomer_pdb))
+    target_atoms = list(iter_atom_lines(target_pdb))
+    if not monomer_atoms:
+        raise ValueError(f"No ATOM/HETATM lines found in monomer PDB: {monomer_pdb}")
+    if not target_atoms:
+        raise ValueError(f"No ATOM/HETATM lines found in target PDB: {target_pdb}")
+
+    target_residue_index: dict[tuple[str, int, str], int] = {}
+    next_target_resseq = 1
+    serial = 1
+
+    out_pdb.parent.mkdir(parents=True, exist_ok=True)
+    with out_pdb.open("w", encoding="utf-8") as handle:
+        for line in monomer_atoms:
+            handle.write(rewrite_atom_line(line, serial, coord_shift=monomer_coord_shift))
+            serial += 1
+        handle.write("TER\n")
+        for line in target_atoms:
+            residue_key = (pdb_chain(line), pdb_resseq(line), pdb_icode(line))
+            if residue_key not in target_residue_index:
+                target_residue_index[residue_key] = next_target_resseq
+                next_target_resseq += 1
+            handle.write(
+                rewrite_atom_line(
+                    line,
+                    serial,
+                    chain_override=target_chain_out,
+                    resseq_override=target_residue_index[residue_key],
+                    icode_override=" ",
+                )
+            )
+            serial += 1
+        handle.write("TER\nEND\n")
+
+
+def read_all_atom_coords(path: Path) -> List[AtomCoord]:
+    return [pdb_xyz(line) for line in iter_atom_lines(path)]
+
+
+def read_intermediate_sections(path: Path) -> tuple[list[AtomCoord], list[AtomCoord]]:
+    monomer_coords: list[AtomCoord] = []
+    target_coords: list[AtomCoord] = []
+    section = 0
+    with path.open("r", encoding="utf-8") as handle:
+        for raw in handle:
+            line = raw.rstrip("\n")
+            if line.startswith("TER"):
+                section += 1
+                continue
+            if not line.startswith(("ATOM", "HETATM")):
+                continue
+            if section == 0:
+                monomer_coords.append(pdb_xyz(line))
+            elif section == 1:
+                target_coords.append(pdb_xyz(line))
+    return monomer_coords, target_coords
+
+
+def max_coord_delta(a: Sequence[AtomCoord], b: Sequence[AtomCoord]) -> float:
+    if len(a) != len(b):
+        raise ValueError(f"Coordinate list length mismatch: {len(a)} vs {len(b)}")
+    max_delta = 0.0
+    for (ax, ay, az), (bx, by, bz) in zip(a, b):
+        delta = math.sqrt((ax - bx) ** 2 + (ay - by) ** 2 + (az - bz) ** 2)
+        max_delta = max(max_delta, delta)
+    return max_delta
+
+
+def validate_intermediate_geometry(
+    monomer_pdb: Path,
+    target_pdb: Path,
+    intermediate_pdb: Path,
+    monomer_coord_shift: AtomCoord | None = None,
+) -> None:
+    src_monomer = read_all_atom_coords(monomer_pdb)
+    src_target = read_all_atom_coords(target_pdb)
+    inter_monomer, inter_target = read_intermediate_sections(intermediate_pdb)
+
+    expected_monomer = [
+        pdb_round_coord(shift_coord(coord, monomer_coord_shift))
+        for coord in src_monomer
+    ]
+    mono_delta = max_coord_delta(expected_monomer, inter_monomer)
+    target_delta = max_coord_delta(src_target, inter_target)
+    if mono_delta != 0.0 or target_delta != 0.0:
+        raise ValueError(
+            f"Coordinate mismatch in {intermediate_pdb}: "
+            f"monomer delta={mono_delta}, target delta={target_delta}"
+        )
