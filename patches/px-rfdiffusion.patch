         #########################################
         ### Parse ligand for ligand potential ###
@@ -800,6 +806,191 @@ class SelfConditioning(Sampler):
     pX0[t+1] is provided as a template input to the model at time t
     """
 
+    def _embedding_guidance_enabled(self):
+        return bool(self.potential_conf.get("embedding_guidance", False)) and (
+            self.potential_manager is not None
+        ) and (not self.potential_manager.is_empty())
+
+    def _embedding_guidance_value(self, key, default):
+        return self.potential_conf.get(key, default)
+
+    def _embedding_guidance_alpha(self, t):
+        alpha = float(self._embedding_guidance_value("embedding_guidance_alpha", 0.01))
+        if bool(self._embedding_guidance_value("embedding_guidance_use_decay", True)):
+            alpha *= float(self.potential_manager.get_guide_scale(t))
+        return alpha
+
+    def _normalized_embedding_step(self, emb, grad, step_size, residue_mask=None, pair_mask=None):
+        if grad is None:
+            return emb.detach()
+
+        grad = torch.nan_to_num(grad)
+        if residue_mask is not None:
+            grad = grad.clone()
+            grad[..., residue_mask, :] = 0
+        if pair_mask is not None:
+            grad = grad * pair_mask
+
+        if bool(self._embedding_guidance_value("embedding_guidance_normalize", True)):
+            grad = grad / (grad.square().mean().sqrt() + 1e-8)
+
+        return (emb + step_size * grad).detach()
+
+    def _embedding_guided_forward(
+        self,
+        *,
+        msa_masked,
+        msa_full,
+        seq_in,
+        xt_in,
+        idx_pdb,
+        t1d,
+        t2d,
+        xyz_t,
+        alpha_t,
+        t,
+    ):
+        motif_mask = self.diffusion_mask.squeeze().to(self.device)
+        fixed_residue_mask = motif_mask.bool()
+        free_residue_mask = ~fixed_residue_mask
+        pair_update_mask = (
+            (free_residue_mask[:, None] | free_residue_mask[None, :])
+            .to(self.device)
+            .reshape(1, fixed_residue_mask.shape[0], fixed_residue_mask.shape[0], 1)
+        )
+
+        msa_latent, msa_full_emb, pair, state = self.model.embed_inputs(
+            msa_masked,
+            msa_full,
+            seq_in,
+            xt_in,
+            idx_pdb,
+            torch.tensor(t, device=self.device),
+            t1d=t1d,
+            t2d=t2d,
+            xyz_t=xyz_t,
+            alpha_t=alpha_t,
+            msa_prev=None,
+            pair_prev=None,
+            state_prev=None,
+            motif_mask=motif_mask,
+            cyclic_reses=self.cyclic_reses,
+        )
+
+        msa_full_emb = msa_full_emb.detach()
+        base_msa_latent = msa_latent.detach()
+        base_pair = pair.detach()
+        base_state = state.detach()
+
+        if bool(self._embedding_guidance_value("embedding_guidance_persist", True)):
+            if (
+                self.embedding_guidance_msa_delta is not None
+                and self.embedding_guidance_msa_delta.shape == msa_latent.shape
+            ):
+                msa_latent = msa_latent + self.embedding_guidance_msa_delta.to(msa_latent.device)
+            if (
+                self.embedding_guidance_pair_delta is not None
+                and self.embedding_guidance_pair_delta.shape == pair.shape
+            ):
+                pair = pair + self.embedding_guidance_pair_delta.to(pair.device)
+            if (
+                self.embedding_guidance_state_delta is not None
+                and self.embedding_guidance_state_delta.shape == state.shape
+            ):
+                state = state + self.embedding_guidance_state_delta.to(state.device)
+
+        update_msa = bool(self._embedding_guidance_value("embedding_guidance_update_msa", True))
+        update_pair = bool(self._embedding_guidance_value("embedding_guidance_update_pair", True))
+        update_state = bool(self._embedding_guidance_value("embedding_guidance_update_state", True))
+        n_steps = int(self._embedding_guidance_value("embedding_guidance_steps", 1))
+        n_steps = max(n_steps, 1)
+
+        for _ in range(n_steps):
+            msa_latent = msa_latent.detach().requires_grad_(update_msa)
+            pair = pair.detach().requires_grad_(update_pair)
+            state = state.detach().requires_grad_(update_state)
+
+            _, _, px0, _, alpha, _, plddt = self.model.forward_from_embeddings(
+                seq_in,
+                xt_in,
+                idx_pdb,
+                msa_latent,
+                msa_full_emb,
+                pair,
+                state,
+                return_infer=True,
+                motif_mask=motif_mask,
+                cyclic_reses=self.cyclic_reses,
+            )
+
+            _, px0_aa = self.allatom(torch.argmax(seq_in, dim=-1), px0, alpha)
+            px0_aa = px0_aa.squeeze()[:, :14]
+            reward = self.potential_manager.compute_all_potentials(px0_aa)
+
+            grad_targets = []
+            grad_names = []
+            if update_msa:
+                grad_targets.append(msa_latent)
+                grad_names.append("msa")
+            if update_pair:
+                grad_targets.append(pair)
+                grad_names.append("pair")
+            if update_state:
+                grad_targets.append(state)
+                grad_names.append("state")
+
+            if not grad_targets or not reward.requires_grad:
+                break
+
+            grads = torch.autograd.grad(
+                reward,
+                grad_targets,
+                retain_graph=False,
+                allow_unused=True,
+            )
+            grad_by_name = dict(zip(grad_names, grads))
+            step_size = self._embedding_guidance_alpha(t)
+
+            msa_latent = self._normalized_embedding_step(
+                msa_latent,
+                grad_by_name.get("msa"),
+                step_size,
+                residue_mask=fixed_residue_mask,
+            )
+            pair = self._normalized_embedding_step(
+                pair,
+                grad_by_name.get("pair"),
+                step_size,
+                pair_mask=pair_update_mask,
+            )
+            state = self._normalized_embedding_step(
+                state,
+                grad_by_name.get("state"),
+                step_size,
+                residue_mask=fixed_residue_mask,
+            )
+
+        if bool(self._embedding_guidance_value("embedding_guidance_persist", True)):
+            self.embedding_guidance_msa_delta = (msa_latent.detach() - base_msa_latent).detach()
+            self.embedding_guidance_pair_delta = (pair.detach() - base_pair).detach()
+            self.embedding_guidance_state_delta = (state.detach() - base_state).detach()
+
+        with torch.no_grad():
+            _, _, px0, _, alpha, _, plddt = self.model.forward_from_embeddings(
+                seq_in,
+                xt_in,
+                idx_pdb,
+                msa_latent,
+                msa_full_emb,
+                pair,
+                state,
+                return_infer=True,
+                motif_mask=motif_mask,
+                cyclic_reses=self.cyclic_reses,
+            )
+
