@@ -0,0 +1,317 @@
+import base64
+import json
+import os
+import sys
+import tempfile
+import unittest
+from pathlib import Path
+from types import SimpleNamespace
+
+from rfdiffusion.openvdb_compat import preload_openvdb
+
+preload_openvdb()
+
+import torch
+
+from rfdiffusion import volume_sketch
+
+REPO_ROOT = Path(__file__).resolve().parents[1]
+TWO_STEP_DIR = REPO_ROOT / "scripts" / "two-step"
+if str(TWO_STEP_DIR) not in sys.path:
+    sys.path.insert(0, str(TWO_STEP_DIR))
+
+import rfdiffusion_runner
+import run_inference_json_twostep as json_twostep
+from rfdiffusion_runner import configure_binder_stage, configure_monomer_stage
+
+
+try:
+    import pyopenvdb as _test_vdb
+except ImportError:
+    _test_vdb = None
+
+
+def _make_test_vdb_data(values):
+    if _test_vdb is None:
+        raise unittest.SkipTest("pyopenvdb is unavailable")
+
+    grid = _test_vdb.FloatGrid()
+    grid.name = "test_sdf"
+    for coord, value in values:
+        grid.fill(tuple(coord), tuple(coord), float(value), True)
+
+    fd, tmp_path = tempfile.mkstemp(suffix=".vdb")
+    os.close(fd)
+    try:
+        _test_vdb.write(tmp_path, grids=[grid])
+        return Path(tmp_path).read_bytes()
+    finally:
+        os.unlink(tmp_path)
+
+
+def _pdb_ca(chain: str, residues: int):
+    lines = []
+    serial = 1
+    for resseq in range(1, residues + 1):
+        lines.append(
+            f"ATOM  {serial:5d}  CA  GLY {chain}{resseq:4d}    "
+            f"{float(resseq):8.3f}{0.0:8.3f}{0.0:8.3f}  1.00  0.00           C"
+        )
+        serial += 1
+    return "\n".join(lines) + "\nEND\n"
+
+
+def _volume_item(values=None, range_pair=(6, 7)):
+    if values is None:
+        return {
+            "format": "OpenVDB",
+            "encoding": "base64",
+            "estimatedMinResidueLength": range_pair[0],
+            "estimatedMaxResidueLength": range_pair[1],
+            "data": "AA==",
+        }
+    raw = _make_test_vdb_data(values)
+    return {
+        "format": "OpenVDB",
+        "encoding": "base64",
+        "gridName": "test_sdf",
+        "estimatedMinResidueLength": range_pair[0],
+        "estimatedMaxResidueLength": range_pair[1],
+        "data": base64.b64encode(raw).decode("ascii"),
+    }
+
+
+def _write_json(*, target=True, volume=True):
+    payload = {
+        "format": "ProteinSketch2AI",
+        "schemaVersion": 2,
+        "targets": []
+        if not target
+        else [
+            {
+                "format": "PDB",
+                "encoding": "utf-8",
+                "data": _pdb_ca("A", 2),
+                "hotspots": ["A1"],
+            }
+        ],
+        "backbones": [],
+        "volumes": [] if not volume else [_volume_item()],
+    }
+    handle = tempfile.NamedTemporaryFile("w", suffix=".ps2ai", delete=False)
+    json.dump(payload, handle)
+    handle.close()
+    return Path(handle.name)
+
+
+class DummySampler:
+    def __init__(self):
+        self.inf_conf = SimpleNamespace()
+        self.diffuser_conf = SimpleNamespace()
+        self.contig_conf = SimpleNamespace()
+        self.potential_conf = SimpleNamespace()
+
+
+class ProteinSketchTwoStepTests(unittest.TestCase):
+    def test_stage_configuration_uses_json_volume_potentials(self):
+        sampler = DummySampler()
+
+        configure_monomer_stage(
+            sampler,
+            target_pdb=Path("target.pdb"),
+            sketch_input=Path("sketch.ps2ai"),
+            monomer_contig="[6-7]",
+            monomer_output_prefix=Path("outputs/monomer"),
