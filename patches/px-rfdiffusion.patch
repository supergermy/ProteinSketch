+def _volume_item(values, range_pair=(6, 7)):
+    raw = _make_test_vdb_data(values)
+    return {
+        "format": "OpenVDB",
+        "encoding": "base64",
+        "gridName": "test_sdf",
+        "estimatedMinResidueLength": int(range_pair[0]),
+        "estimatedMaxResidueLength": int(range_pair[1]),
+        "data": base64.b64encode(raw).decode("ascii"),
+    }
