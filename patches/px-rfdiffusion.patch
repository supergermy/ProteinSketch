+    x = float(line[30:38]) - float(shift[0])
+    y = float(line[38:46]) - float(shift[1])
+    z = float(line[46:54]) - float(shift[2])
+    chars = list(line.rstrip("\n").ljust(80))
+    chars[30:38] = list(f"{x:8.3f}")
+    chars[38:46] = list(f"{y:8.3f}")
+    chars[46:54] = list(f"{z:8.3f}")
+    return "".join(chars).rstrip()
