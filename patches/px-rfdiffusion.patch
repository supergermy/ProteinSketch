+def _pdb_ca(chain: str, residues: int, *, x_offset=0.0):
+    lines = []
+    serial = 1
+    for resseq in range(1, residues + 1):
+        x = float(x_offset + resseq)
+        for atom, y, element in (
+            ("N", 0.0, "N"),
+            ("CA", 1.0, "C"),
+            ("C", 2.0, "C"),
+            ("O", 3.0, "O"),
+        ):
+            lines.append(
+                f"ATOM  {serial:5d}  {atom:<3} GLY {chain}{resseq:4d}    "
+                f"{x:8.3f}{y:8.3f}{0.0:8.3f}  1.00  0.00           {element}"
+            )
+            serial += 1
+    return "\n".join(lines) + "\nEND\n"
+
+
+def _write_json(payload) -> Path:
+    handle = tempfile.NamedTemporaryFile("w", suffix=".ps2ai", delete=False)
+    json.dump(payload, handle)
+    handle.close()
+    return Path(handle.name)
+
