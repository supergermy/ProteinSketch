+from __future__ import annotations
+
+import base64
+import json
+import os
+import tempfile
+from dataclasses import dataclass
+from pathlib import Path
+from typing import Optional
+
+import numpy as np
+import torch
+
+from rfdiffusion.openvdb_compat import import_openvdb
+
+
+_PROTEINSKETCH_JSON_CACHE: dict[str, dict] = {}
+_VOLUME_SKETCH_RAW_POINTS_CACHE: dict[tuple, tuple[np.ndarray, list]] = {}
+_PROTEINSKETCH_FORMATS = {"ProteinSketch2AI", "ProteinSketchOutput"}
+_PROTEINSKETCH_SECTION_KEYS = {
+    "target": ("targets", "target"),
+    "targets": ("targets", "target"),
+    "backbone": ("backbones", "backbone"),
+    "backbones": ("backbones", "backbone"),
+    "volume": ("volumes", "volume"),
+    "volumes": ("volumes", "volume"),
+}
+
+
+def clear_volume_sketch_cache() -> None:
+    _PROTEINSKETCH_JSON_CACHE.clear()
+    _VOLUME_SKETCH_RAW_POINTS_CACHE.clear()
+
+
+def _volume_sketch_path_key(path) -> str:
+    return str(Path(path).expanduser().resolve())
+
+
+def _import_openvdb_module():
+    return import_openvdb()
+
+
+def load_proteinsketch_input(json_path) -> dict:
+    path = Path(json_path)
+    cache_key = _volume_sketch_path_key(path)
+    cached = _PROTEINSKETCH_JSON_CACHE.get(cache_key)
+    if cached is not None:
+        return cached
+
+    with path.open("r", encoding="utf-8-sig") as handle:
+        payload = json.load(handle)
+    if not isinstance(payload, dict):
+        raise ValueError(f"ProteinSketch2AI root must be an object: {path}")
+    if payload.get("format") not in _PROTEINSKETCH_FORMATS:
+        raise ValueError(f"Input file is not a ProteinSketch2AI file: {path}")
+
+    _PROTEINSKETCH_JSON_CACHE[cache_key] = payload
+    return payload
+
+
+def _proteinsketch_section_items(payload: dict, section: str) -> list[dict]:
+    section_keys = _PROTEINSKETCH_SECTION_KEYS.get(section, (section,))
+    key = section_keys[0]
+    value = None
+    for candidate in section_keys:
+        if candidate in payload:
+            key = candidate
+            value = payload.get(candidate)
+            break
+    if value is None:
+        return []
+    if not isinstance(value, list):
+        raise ValueError(f"ProteinSketch2AI section {key!r} must be a list or null")
+    return [item for item in value if isinstance(item, dict)]
+
+
+def proteinsketch_section_items(json_path, section: str) -> list[dict]:
+    return _proteinsketch_section_items(load_proteinsketch_input(json_path), section)
+
+
+def proteinsketch_has_section(json_path, section: str) -> bool:
+    return len(proteinsketch_section_items(json_path, section)) > 0
+
+
+def _proteinsketch_item_text(item: dict, section: str, json_path) -> str:
+    if "data" not in item:
+        raise ValueError(f"ProteinSketch2AI {section} entry has no PDB data: {json_path}")
+    text = item["data"]
+    encoding = str(item.get("encoding", "utf-8")).lower()
+    if encoding == "base64":
+        text = base64.b64decode(text).decode("utf-8")
+    if not isinstance(text, str) or "ATOM" not in text:
+        raise ValueError(f"ProteinSketch2AI {section} entry is not PDB text: {json_path}")
+    return text if text.endswith("\n") else text + "\n"
+
+
+def proteinsketch_pdb_text(json_path, section: str, index: int = 0) -> str:
+    items = proteinsketch_section_items(json_path, section)
+    if index < 0 or index >= len(items):
+        raise ValueError(f"ProteinSketch2AI has no {section}[{index}] entry: {json_path}")
+    item = items[index]
+    if str(item.get("format", "PDB")).upper() != "PDB":
+        raise ValueError(f"ProteinSketch2AI {section}[{index}] is not PDB format: {json_path}")
+    return _proteinsketch_item_text(item, section, json_path)
+
+
+def _atom_line_with_chain(line: str, chain_id: str, resseq: int | None = None, serial: int | None = None) -> str:
+    if not line.startswith(("ATOM  ", "HETATM")):
+        return line
+    chars = list(line.rstrip("\n").ljust(80))
+    if serial is not None:
+        chars[6:11] = list(f"{serial:5d}"[-5:])
+    chars[21] = chain_id
+    if resseq is not None:
+        chars[22:26] = list(f"{resseq:4d}"[-4:])
+    return "".join(chars).rstrip()
+
+
+def _rewrite_pdb_text(text: str, *, chain_id: str | None = None, renumber: bool = False, serial_start: int = 1):
+    residue_map: dict[tuple[str, int, str], int] = {}
+    next_resseq = 1
+    serial = int(serial_start)
+    lines = []
+    for raw in text.splitlines():
+        if not raw.startswith(("ATOM  ", "HETATM")):
+            continue
+        old_chain = raw[21:22].strip() or "A"
+        old_resseq = int(raw[22:26].strip())
+        old_icode = raw[26:27]
+        key = (old_chain, old_resseq, old_icode)
+        new_resseq = None
+        if renumber:
+            if key not in residue_map:
+                residue_map[key] = next_resseq
+                next_resseq += 1
+            new_resseq = residue_map[key]
+        lines.append(_atom_line_with_chain(raw, chain_id or old_chain, new_resseq, serial))
+        serial += 1
+    if not lines:
+        raise ValueError("ProteinSketch PDB text has no ATOM/HETATM rows")
+    count = len(residue_map) if renumber else len({line[21:26] for line in lines})
+    return "\n".join(lines) + "\nEND\n", count
+
+
+def write_proteinsketch_pdb(json_path, section: str, output_path, *, chain_id: str | None = None, renumber: bool = False) -> Path:
+    text = proteinsketch_pdb_text(json_path, section)
+    rewritten, _count = _rewrite_pdb_text(text, chain_id=chain_id, renumber=renumber)
+    path = Path(output_path)
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(rewritten, encoding="utf-8")
+    return path
+
+
+def write_proteinsketch_complex_pdb(json_path, output_path, *, backbone_chain: str = "Z") -> tuple[Path, int]:
+    backbone_text = proteinsketch_pdb_text(json_path, "backbone")
+    target_text = proteinsketch_pdb_text(json_path, "target")
+    backbone_rewritten, backbone_len = _rewrite_pdb_text(
+        backbone_text,
+        chain_id=backbone_chain,
+        renumber=True,
+        serial_start=1,
+    )
+    backbone_lines = [line for line in backbone_rewritten.splitlines() if line.startswith(("ATOM  ", "HETATM"))]
+    target_rewritten, _target_len = _rewrite_pdb_text(
+        target_text,
+        chain_id=None,
+        renumber=False,
+        serial_start=len(backbone_lines) + 1,
+    )
+    target_lines = [line for line in target_rewritten.splitlines() if line.startswith(("ATOM  ", "HETATM"))]
+    path = Path(output_path)
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text("\n".join([*backbone_lines, *target_lines]) + "\nEND\n", encoding="utf-8")
+    return path, backbone_len
+
+
+def proteinsketch_pdb_length(json_path, section: str) -> int:
+    text = proteinsketch_pdb_text(json_path, section)
+    _rewritten, count = _rewrite_pdb_text(text, chain_id=None, renumber=True)
+    return count
+
+
+def proteinsketch_target_hotspots(json_path) -> list[str]:
+    items = proteinsketch_section_items(json_path, "target")
+    if not items:
+        return []
+    hotspots = items[0].get("hotspots", [])
+    if hotspots is None:
+        return []
+    return [str(item) for item in hotspots]
+
+
+def proteinsketch_volume_length_range(json_path, volume_index: int = 0) -> Optional[str]:
+    items = proteinsketch_section_items(json_path, "volume")
+    if volume_index < 0 or volume_index >= len(items):
+        return None
+    item = items[volume_index]
+    min_len = item.get("estimatedMinResidueLength")
+    max_len = item.get("estimatedMaxResidueLength")
+    if min_len is not None and max_len is not None:
+        return f"{int(min_len)}-{int(max_len)}"
+    value = item.get("estimatedResidueCountRange")
+    if isinstance(value, dict) and "min" in value and "max" in value:
+        return f"{int(value['min'])}-{int(value['max'])}"
+    return None
+
+
+def proteinsketch_mode(json_path) -> str:
+    has_target = proteinsketch_has_section(json_path, "target")
+    has_backbone = proteinsketch_has_section(json_path, "backbone")
+    has_volume = proteinsketch_has_section(json_path, "volume")
+    if has_target and has_backbone:
+        return "binder_partial"
+    if has_backbone:
+        return "monomer_partial"
+    if has_target and has_volume:
+        return "binder"
+    if has_volume:
+        return "monomer"
+    raise ValueError(f"ProteinSketch2AI has no usable targets/backbones/volumes input: {json_path}")
+
+
+def protein_contig_ranges(pdb_path) -> list[str]:
+    if pdb_path is None:
+        return []
+
+    path = Path(pdb_path)
+    chain_order: list[str] = []
+    residues_by_chain: dict[str, set[int]] = {}
+    with path.open("r", encoding="utf-8") as handle:
+        for line in handle:
+            if line[:4] != "ATOM" or line[12:16].strip() != "CA":
+                continue
+            chain = line[21:22].strip()
+            if not chain:
+                raise ValueError(f"Blank chain ID in protein residue row: {line.rstrip()}")
+            resnum = int(line[22:26].strip())
+            if chain not in residues_by_chain:
+                residues_by_chain[chain] = set()
+                chain_order.append(chain)
+            residues_by_chain[chain].add(resnum)
+
+    ranges: list[str] = []
+    for chain in chain_order:
+        residues = sorted(residues_by_chain[chain])
+        if not residues:
+            continue
+        start = prev = residues[0]
+        for resnum in residues[1:]:
+            if resnum == prev + 1:
+                prev = resnum
+                continue
+            ranges.append(f"{chain}{start}-{prev}")
+            start = prev = resnum
+        ranges.append(f"{chain}{start}-{prev}")
+    return ranges
+
+
+def _proteinsketch_vdb_payload(json_path, volume_index: int = 0) -> dict:
+    volume_items = proteinsketch_section_items(json_path, "volume")
+    if volume_index < 0 or volume_index >= len(volume_items):
+        raise ValueError(f"ProteinSketch2AI has no volumes[{volume_index}] object: {json_path}")
+    vdb_payload = volume_items[volume_index]
+    if vdb_payload.get("format") != "OpenVDB":
+        raise ValueError(f"ProteinSketch2AI volumes[{volume_index}] is not OpenVDB data: {json_path}")
+    if vdb_payload.get("encoding") != "base64":
+        raise ValueError(f"ProteinSketch2AI volumes[{volume_index}].encoding must be base64: {json_path}")
+    return vdb_payload
+
+
+def validate_proteinsketch_volume_json(json_path, volume_index: int = 0) -> None:
+    _proteinsketch_vdb_payload(json_path, volume_index=volume_index)
+
+
+def _extract_vdb_bytes_from_proteinsketch_input(json_path, volume_index: int = 0) -> bytes:
+    vdb_payload = _proteinsketch_vdb_payload(json_path, volume_index=volume_index)
+    data = vdb_payload.get("data")
+    if not isinstance(data, str) or not data.strip():
+        raise ValueError(f"ProteinSketch2AI has empty volumes[{volume_index}].data: {json_path}")
+    return base64.b64decode(data)
+
+
+def _read_vdb_grids_from_json(json_path, volume_index: int = 0):
+    vdb = _import_openvdb_module()
+    raw = _extract_vdb_bytes_from_proteinsketch_input(json_path, volume_index=volume_index)
+    fd, tmp_path = tempfile.mkstemp(suffix=".vdb")
+    os.close(fd)
+    try:
+        with open(tmp_path, "wb") as handle:
+            handle.write(raw)
+        grids, _metadata = vdb.readAll(tmp_path)
+    finally:
+        try:
+            os.unlink(tmp_path)
+        except OSError:
+            pass
+    return list(grids)
+
+
+def _choose_vdb_grid(json_path, grid_name=None, volume_index: int = 0):
+    grids = _read_vdb_grids_from_json(json_path, volume_index=volume_index)
+    if not grids:
+        raise ValueError(f"No grids found in ProteinSketch VDB JSON: {json_path}")
+
+    requested = grid_name or _proteinsketch_vdb_payload(json_path, volume_index=volume_index).get("gridName")
+    if requested:
+        for grid in grids:
+            if getattr(grid, "name", "") == requested:
+                return grid
+        raise ValueError(f"Grid {requested!r} not found in ProteinSketch VDB JSON: {json_path}")
+    return grids[0]
+
+
+def _coord3(value) -> tuple[int, int, int]:
+    return (int(value[0]), int(value[1]), int(value[2]))
+
+
+def _vdb_item_field(item, key: str):
+    if hasattr(item, key):
+        return getattr(item, key)
+    return item[key]
+
+
+def _iter_vdb_item_coords(item):
+    min_coord = _coord3(_vdb_item_field(item, "min"))
+    max_coord = _coord3(_vdb_item_field(item, "max"))
+    for z in range(min_coord[2], max_coord[2] + 1):
+        for y in range(min_coord[1], max_coord[1] + 1):
+            for x in range(min_coord[0], max_coord[0] + 1):
+                yield (x, y, z)
+
+
+def _default_vdb_min_sdf(cutoff) -> float:
+    return -1.0 if cutoff is None else float(cutoff)
+
+
+def _default_vdb_max_sdf(max_sdf) -> float:
+    return 0.0 if max_sdf is None else float(max_sdf)
+
+
+@dataclass(frozen=True)
+class SketchVDBGrid:
+    json_path: str
+    grid_name: str
+    volume_index: int
+    min_sdf: float
+    max_sdf: float
+    shell_points: np.ndarray
+    shell_sdf: np.ndarray
+    shell_index_coords: np.ndarray
+    grid: object
+    shift: np.ndarray
+
+    @property
+    def backend(self) -> str:
+        return "vdb"
+
+    @property
+    def kind(self) -> str:
+        return "vdb"
+
+    @property
+    def label(self) -> str:
+        return self.grid_name or "vdb"
+
+    @property
+    def center(self) -> np.ndarray:
+        if self.shell_points.size == 0:
+            return np.zeros(3, dtype=np.float32)
+        return self.shell_points.mean(axis=0).astype(np.float32)
+
+    @property
+    def radius(self) -> float:
+        if self.shell_points.size == 0:
+            return 0.0
+        center = self.center
+        return float(np.linalg.norm(self.shell_points - center[None, :], axis=1).max())
+
+    @property
+    def geometries(self):
+        return [self]
+
+
+def _vdb_shell_grid(json_path, cutoff=None, max_sdf=None, grid_name=None, volume_index: int = 0) -> SketchVDBGrid:
+    min_sdf = _default_vdb_min_sdf(cutoff)
+    max_sdf = _default_vdb_max_sdf(max_sdf)
+    if min_sdf > max_sdf:
+        raise ValueError(f"VDB min_sdf must be <= max_sdf; got {min_sdf} > {max_sdf}")
+
+    grid = _choose_vdb_grid(json_path, grid_name=grid_name, volume_index=volume_index)
+    points: list[tuple[float, float, float]] = []
+    values: list[float] = []
+    index_coords: list[tuple[int, int, int]] = []
+    transform = grid.transform
+    for item in grid.iterOnValues():
+        value = float(_vdb_item_field(item, "value"))
+        if value < min_sdf or value > max_sdf:
+            continue
+        for coord in _iter_vdb_item_coords(item):
+            world = transform.indexToWorld(coord)
+            points.append((float(world[0]), float(world[1]), float(world[2])))
+            values.append(value)
+            index_coords.append(coord)
+
+    return SketchVDBGrid(
+        json_path=_volume_sketch_path_key(json_path),
+        grid_name=str(getattr(grid, "name", "")),
+        volume_index=int(volume_index),
+        min_sdf=min_sdf,
+        max_sdf=max_sdf,
+        shell_points=np.asarray(points, dtype=np.float32).reshape(-1, 3),
+        shell_sdf=np.asarray(values, dtype=np.float32),
+        shell_index_coords=np.asarray(index_coords, dtype=np.int32).reshape(-1, 3),
+        grid=grid,
+        shift=np.zeros(3, dtype=np.float32),
+    )
+
+
+def _shift_vdb_grid(grid: SketchVDBGrid, shift) -> SketchVDBGrid:
+    shift = np.asarray(shift, dtype=np.float32)
+    return SketchVDBGrid(
+        json_path=grid.json_path,
+        grid_name=grid.grid_name,
+        volume_index=grid.volume_index,
+        min_sdf=grid.min_sdf,
+        max_sdf=grid.max_sdf,
+        shell_points=(grid.shell_points - shift).astype(np.float32),
+        shell_sdf=grid.shell_sdf,
+        shell_index_coords=grid.shell_index_coords,
+        grid=grid.grid,
+        shift=(grid.shift + shift).astype(np.float32),
+    )
+
+
+def _raw_volume_sketch_points(json_path, *, cutoff, max_sdf, volume_index: int) -> tuple[np.ndarray, list]:
+    cache_key = (
+        _volume_sketch_path_key(json_path),
+        "vdb",
+        int(volume_index),
+        None if cutoff is None else float(cutoff),
+        None if max_sdf is None else float(max_sdf),
+    )
+    cached = _VOLUME_SKETCH_RAW_POINTS_CACHE.get(cache_key)
+    if cached is not None:
+        return cached
+
+    grid = _vdb_shell_grid(json_path, cutoff=cutoff, max_sdf=max_sdf, volume_index=int(volume_index))
+    if grid.shell_points.size == 0:
+        raise ValueError(f"No VDB shell points found in ProteinSketch2AI {json_path}")
+    raw = (grid.shell_points.astype(np.float32), [grid])
+    _VOLUME_SKETCH_RAW_POINTS_CACHE[cache_key] = raw
+    return raw
+
+
+def volume_sketch_points(
+    json_path,
+    *,
+    backend="vdb",
+    target_center=None,
+    centered=False,
+    cutoff=None,
+    max_sdf=None,
+    volume_index=0,
+    **_unused,
+) -> tuple[torch.Tensor, list]:
+    backend = str(backend or "vdb").strip().lower()
+    if backend != "vdb":
+        raise ValueError("ProteinSketch2AI branch supports only backend='vdb'")
+
+    shift = np.zeros(3, dtype=np.float32)
+    if target_center is not None:
+        shift = np.asarray(target_center, dtype=np.float32).reshape(-1, 3).mean(axis=0)
+
+    raw_points, raw_geometries = _raw_volume_sketch_points(
+        json_path,
+        cutoff=cutoff,
+        max_sdf=max_sdf,
+        volume_index=int(volume_index),
+    )
+    shifted_points = (raw_points - shift).astype(np.float32)
+    shifted_geometries = [_shift_vdb_grid(geometry, shift) for geometry in raw_geometries]
+
+    if centered:
+        com = shifted_points.mean(axis=0).astype(np.float32)
+        shifted_points = (shifted_points - com).astype(np.float32)
+        shifted_geometries = [_shift_vdb_grid(geometry, com) for geometry in shifted_geometries]
+
+    return torch.from_numpy(shifted_points), shifted_geometries
+
+
+def _as_points_array(points) -> np.ndarray:
+    if isinstance(points, torch.Tensor):
+        points = points.detach().cpu().numpy()
+    return np.asarray(points, dtype=np.float32).reshape(-1, 3)
+
+
+def _vdb_sdf(points: np.ndarray, grid: SketchVDBGrid) -> np.ndarray:
+    coords = _as_points_array(points)
+    shifted = coords + np.asarray(grid.shift, dtype=np.float32)[None, :]
+    accessor = grid.grid.getConstAccessor()
+    values = []
+    for point in shifted:
+        index = grid.grid.transform.worldToIndex(tuple(float(x) for x in point))
+        coord = tuple(int(round(float(index[i]))) for i in range(3))
+        values.append(float(accessor.getValue(coord)))
+    return np.asarray(values, dtype=np.float32)
+
+
+def points_inside_geometries(
+    points,
+    geometries,
+    *,
+    backend=None,
+    max_sdf=None,
+    **_unused,
+) -> np.ndarray:
+    coords = _as_points_array(points)
+    inside = np.zeros(coords.shape[0], dtype=bool)
+    backend = None if backend is None else str(backend).strip().lower()
+    if backend not in {None, "vdb"}:
+        raise ValueError("ProteinSketch2AI branch supports only backend='vdb'")
+    for geometry in geometries:
+        if not isinstance(geometry, SketchVDBGrid):
+            raise TypeError(f"Unknown ProteinSketch geometry: {geometry!r}")
+        inside |= _vdb_sdf(coords, geometry) <= _default_vdb_max_sdf(max_sdf)
+    return inside
+
+
+def write_volume_shell_points_pdb(
+    pdb_path,
+    points,
+    geometries,
+    *,
+    chain_id: str = "V",
+) -> Path:
+    path = Path(pdb_path)
+    path.parent.mkdir(parents=True, exist_ok=True)
+    coords = _as_points_array(points)
+    if not geometries:
+        raise ValueError("At least one VDB geometry is required to write shell points")
+
+    grid_counts = [len(getattr(geometry, "shell_points", [])) for geometry in geometries]
+    if sum(grid_counts) == len(coords) and all(count > 0 for count in grid_counts):
+        point_geometry_indices = []
+        for idx, count in enumerate(grid_counts):
+            point_geometry_indices.extend([idx] * count)
+    else:
+        point_geometry_indices = [0 for _ in range(len(coords))]
+
+    chain = (str(chain_id).strip() or "V")[0]
+    with path.open("w", encoding="utf-8") as handle:
+        handle.write("REMARK PROTEINSKETCH_VDB_SHELL_POINTS\n")
+        for i, geometry in enumerate(geometries, start=1):
+            handle.write(
+                "REMARK PROTEINSKETCH_VDB_GEOMETRY "
+                f"{i} grid_name={geometry.grid_name} volume_index={geometry.volume_index} "
+                f"min_sdf={geometry.min_sdf:.3f} max_sdf={geometry.max_sdf:.3f}\n"
+            )
+        for point_idx, (x, y, z) in enumerate(coords, start=1):
+            geometry_idx = point_geometry_indices[point_idx - 1]
+            geometry = geometries[geometry_idx]
+            serial = point_idx if point_idx <= 99999 else ((point_idx - 1) % 99999) + 1
+            resseq = geometry_idx + 1
+            handle.write(
+                f"HETATM{serial:5d}  SPH VSP {chain}{resseq:4d}    "
+                f"{x:8.3f}{y:8.3f}{z:8.3f}"
+                f"{1.00:6.2f}{float(geometry.radius):6.2f}          C\n"
+            )
+        handle.write("END\n")
+    return path
